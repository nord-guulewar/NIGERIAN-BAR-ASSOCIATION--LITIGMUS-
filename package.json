{
  "name": "nba-litigmus",
  "version": "1.0.0",
  "description": "Nigerian Bar Association Complete Court Management System",
  "private": true,
  "scripts": {
    "install:all": "cd backend && npm install && cd ../frontend && npm install",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm start",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "start:backend": "cd backend && npm start",
    "start:frontend": "cd frontend && npm start",
    "start:cluster": "cd backend && npm run start:cluster",
    "start:prod": "cd backend && npm run start:prod",
    "docker:build": "cd backend && docker build -t nba-litigmus .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:restart": "docker-compose restart",
    "sync:policies": "node scripts/syncPoliciesToFrontend.js",
    "pm2:start": "cd backend && pm2 start ecosystem.config.js --env production",
    "pm2:stop": "cd backend && pm2 stop ecosystem.config.js",
    "pm2:restart": "cd backend && pm2 restart ecosystem.config.js",
    "pm2:logs": "cd backend && pm2 logs",
    "pm2:monit": "cd backend && pm2 monit",
    "test": "cd backend && npm test",
    "test:all": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd backend && npm test",
    "test:frontend": "cd frontend && npm test -- --watchAll=false"
  },
  "keywords": [
    "nba",
    "nigerian-bar-association",
    "court-management",
    "case-management",
    "legal-tech",
    "nigeria"
  ],
  "author": "Nigerian Bar Association",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "dependencies": {
    "firebase": "^12.15.0"
  }
}
