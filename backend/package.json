{
  "name": "nba-litigmus-backend",
  "version": "1.0.0",
  "description": "Nigerian Bar Association Case Management System - Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:cluster": "node cluster.js",
    "start:prod": "pm2 start ecosystem.config.js --env production",
    "stop": "pm2 stop ecosystem.config.js",
    "restart": "pm2 restart ecosystem.config.js",
    "logs": "pm2 logs",
    "monit": "pm2 monit",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "db:bootstrap": "node scripts/bootstrapDatabase.js",
    "db:bootstrap:test": "NODE_ENV=test node scripts/bootstrapDatabase.js",
    "seed": "npm run db:bootstrap && SEED_MODE=upsert node seed.js",
    "seed:reset": "npm run db:bootstrap && ALLOW_DESTRUCTIVE_SEED=true SEED_MODE=reset node seed.js",
    "seed:test": "NODE_ENV=test node scripts/seedTest.js",
    "db:apply-rls": "node scripts/applyRls.js",
    "docker:build": "docker build -t nba-litigmus .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "nba",
    "case-management",
    "court",
    "nigeria"
  ],
  "author": "Nigerian Bar Association",
  "license": "ISC",
  "dependencies": {
    "@sendinblue/client": "^3.3.1",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^6.10.0",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "firebase-admin": "^14.1.0",
    "helmet": "^7.0.0",
    "hpp": "^0.2.3",
    "joi": "^17.10.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^6.9.4",
    "pg": "^8.21.0",
    "pm2": "^5.3.0",
    "redis": "^4.6.0",
    "sequelize": "^6.37.8",
    "twilio": "^5.13.1",
    "uuid": "^9.0.0",
    "validator": "^13.15.35",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "jest": "^29.6.4",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  }
}
