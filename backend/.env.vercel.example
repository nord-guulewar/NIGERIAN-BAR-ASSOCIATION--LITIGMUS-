NODE_ENV=production
PORT=5000

# Core backend
DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST:5432/DATABASE
DATABASE_REPLICA_URL=
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=7d
SESSION_SECRET=replace_with_a_long_random_session_secret
ENCRYPTION_KEY=replace_with_exactly_32_characters
FRONTEND_URL=https://litigmus-app.vercel.app/

# Redis (optional)
REDIS_ENABLED=false
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Firebase Admin bridge (only if enabled)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace_with_private_key\n-----END PRIVATE KEY-----\n"

# Email delivery
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Payments (optional)
PAYSTACK_SECRET_KEY=
FLUTTERWAVE_SECRET_KEY=

# WhatsApp / Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Governance / operations
DPO_EMAIL=
DPO_PHONE=
SECURITY_EMAIL=
DATA_RETENTION_PERIOD=2555
AUTO_DELETE_READ_NOTIFICATIONS=false

# External verification providers (optional)
BAR_API_KEY=
BAR_API_BASE_URL=https://api.nigerianbar.org/v1
BAR_VERIFICATION_PROVIDER=demo
BAR_API_TIMEOUT_MS=15000
NIN_API_KEY=
NIN_API_BASE_URL=
NIN_VERIFICATION_PROVIDER=verifyme
NIN_VERIFICATION_CALLBACK_URL=
NIN_API_TIMEOUT_MS=15000
NIMC_API_BASE_URL=
NIMC_USERNAME=
NIMC_PASSWORD=

# Pool and rate tuning (optional)
DB_SSL=true
DB_POOL_PER_WORKER=10
DB_POOL_BUDGET=80
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000
DB_STATEMENT_TIMEOUT_MS=30000
DB_TX_IDLE_TIMEOUT_MS=15000
DB_CONCURRENCY_LIMIT=12
DB_QUEUE_LIMIT=50
DB_WRITE_WINDOW_SECONDS=60
DB_WRITE_LIMIT_ADMIN=500
DB_WRITE_LIMIT_REGISTRAR=120
DB_WRITE_LIMIT_CLERK=80
DB_WRITE_LIMIT_ACCOUNTANT=80
DB_WRITE_LIMIT_CASHIER=60
DB_WRITE_LIMIT_JUDGE=40
DB_WRITE_LIMIT_BAILIFF=40
DB_WRITE_LIMIT_DEFAULT=30
DB_READ_WINDOW_SECONDS=60
DB_READ_LIMIT_AUTHED=300
DB_READ_LIMIT_ANON=60

# Misc
INCIDENT_LOG_PATH=/tmp/litigmus-incidents.log